{
  "expo": {
    "name": "Garcom_GO",
    "slug": "Garcom_GO",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "garcomgo",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/logo.png",
          "color": "#337acc"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "image": "./src/assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#e9f0ff"
    }
  }
}
